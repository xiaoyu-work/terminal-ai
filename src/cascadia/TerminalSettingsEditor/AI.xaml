<Page x:Class="Microsoft.Terminal.Settings.Editor.AI"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Microsoft.Terminal.Settings.Editor"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:mtu="using:Microsoft.Terminal.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CommonResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <StackPanel>
        <StackPanel Style="{StaticResource SettingsStackStyle}">

            <!--  Copilot OAuth Login  -->
            <local:SettingContainer x:Name="AI_CopilotAuth"
                                    x:Uid="AI_CopilotAuth">
                <StackPanel Spacing="8">
                    <!--  Connected state  -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{x:Bind ViewModel.IsCopilotAuthLoggedIn, Mode=OneWay}">
                        <FontIcon Glyph="&#xE73E;"
                                  Foreground="Green"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Uid="AI_CopilotAuthConnected"
                                   VerticalAlignment="Center" />
                        <Button x:Uid="AI_CopilotAuthDisconnectButton"
                                Click="{x:Bind ViewModel.Disconnect}" />
                    </StackPanel>

                    <!--  Not connected, not in progress  -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{x:Bind mtu:Converters.InvertedBooleanToVisibility(ViewModel.IsCopilotAuthLoggedIn), Mode=OneWay}">

                        <!--  Sign-in button (hidden during OAuth flow)  -->
                        <Button x:Uid="AI_CopilotAuthLoginButton"
                                Click="{x:Bind ViewModel.CopilotAuthLogin}"
                                Visibility="{x:Bind mtu:Converters.InvertedBooleanToVisibility(ViewModel.IsOAuthInProgress), Mode=OneWay}" />

                        <FontIcon Glyph="&#xE783;"
                                  Foreground="Red"
                                  VerticalAlignment="Center"
                                  Visibility="{x:Bind mtu:Converters.InvertedBooleanToVisibility(ViewModel.IsOAuthInProgress), Mode=OneWay}" />
                    </StackPanel>

                    <!--  Device code flow in progress  -->
                    <StackPanel Visibility="{x:Bind ViewModel.IsOAuthInProgress, Mode=OneWay}"
                                Spacing="12">
                        <TextBlock x:Uid="AI_DeviceCodeInstruction"
                                   TextWrapping="Wrap" />

                        <!--  User code display  -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock x:Uid="AI_DeviceCodeLabel"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.UserCode, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       IsTextSelectionEnabled="True" />
                            <Button x:Uid="AI_DeviceCodeCopyButton"
                                    Click="{x:Bind ViewModel.CopyUserCode}"
                                    Padding="6,4" />
                        </StackPanel>

                        <!--  Open URL button  -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Button x:Uid="AI_DeviceCodeOpenButton"
                                    Click="{x:Bind ViewModel.OpenVerificationUri}" />
                            <TextBlock Text="{x:Bind ViewModel.VerificationUri, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource SystemBaseMediumColor}"
                                       IsTextSelectionEnabled="True" />
                        </StackPanel>

                        <!--  Waiting indicator and cancel  -->
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <muxc:ProgressRing IsActive="True"
                                               Width="16"
                                               Height="16" />
                            <TextBlock x:Uid="AI_DeviceCodeWaiting"
                                       VerticalAlignment="Center" />
                            <Button x:Uid="AI_DeviceCodeCancelButton"
                                    Click="{x:Bind ViewModel.CancelOAuth}"
                                    Padding="6,4" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Error message  -->
                    <TextBlock Text="{x:Bind ViewModel.OAuthError, Mode=OneWay}"
                               Foreground="Red"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind mtu:Converters.StringNotEmptyToVisibility(ViewModel.OAuthError), Mode=OneWay}" />
                </StackPanel>
            </local:SettingContainer>
        </StackPanel>

        <StackPanel Style="{StaticResource SettingsStackStyle}">
            <!--  Grouping: Advanced  -->
            <TextBlock x:Uid="AI_AdvancedHeader"
                       Style="{StaticResource TextBlockSubHeaderStyle}" />

            <!--  Max Context Blocks  -->
            <local:SettingContainer x:Name="AI_MaxContextBlocks"
                                    x:Uid="AI_MaxContextBlocks">
                <muxc:NumberBox Maximum="20"
                                Minimum="1"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Style="{StaticResource NumberBoxSettingStyle}"
                                Value="{x:Bind ViewModel.MaxContextBlocks, Mode=TwoWay}" />
            </local:SettingContainer>

            <!--  Copilot CLI Path  -->
            <local:SettingContainer x:Name="AI_CopilotCliPath"
                                    x:Uid="AI_CopilotCliPath">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <TextBox IsSpellCheckEnabled="False"
                             Width="320"
                             PlaceholderText="copilot (searches PATH)"
                             Text="{x:Bind ViewModel.CopilotCliPath, Mode=TwoWay}" />
                    <FontIcon Glyph="&#xE73E;"
                              Foreground="Green"
                              VerticalAlignment="Center"
                              Visibility="{x:Bind ViewModel.IsCopilotCliDetected, Mode=OneWay}" />
                    <FontIcon Glyph="&#xE783;"
                              Foreground="Red"
                              VerticalAlignment="Center"
                              Visibility="{x:Bind mtu:Converters.InvertedBooleanToVisibility(ViewModel.IsCopilotCliDetected), Mode=OneWay}" />
                </StackPanel>
            </local:SettingContainer>
        </StackPanel>
    </StackPanel>
</Page>
